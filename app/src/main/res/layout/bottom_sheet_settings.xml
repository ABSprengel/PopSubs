<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="560dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceHeadline6" />

        <!-- Text size -->
        <TextView
            android:id="@+id/labelTextSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_text_size" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderTextSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="1.0"
            android:valueFrom="12.0"
            android:valueTo="48.0" />

        <!-- Text color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setting_text_color" />

        <LinearLayout
            android:id="@+id/rowTextColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal" />

        <!-- Box color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_box_color" />

        <LinearLayout
            android:id="@+id/rowBoxColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal" />

        <!-- Playback speed -->
        <TextView
            android:id="@+id/labelSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_playback_speed" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="0.25"
            android:valueFrom="0.5"
            android:valueTo="2.0" />

        <!-- Keep screen awake -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchKeepScreenOn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setting_keep_screen_on" />

        <!-- Pre-roll -->
        <TextView
            android:id="@+id/labelPreRoll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_pre_roll" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderPreRoll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="100.0"
            android:valueFrom="0.0"
            android:valueTo="3000.0" />

        <!-- Post-roll -->
        <TextView
            android:id="@+id/labelPostRoll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/setting_post_roll" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderPostRoll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="100.0"
            android:valueFrom="0.0"
            android:valueTo="3000.0" />

        <!-- Time display format -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_time_format" />

        <RadioGroup
            android:id="@+id/radioGroupTimeFormat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <RadioButton
                android:id="@+id/radioTimeMMSSms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MM:SS.mmm  (e.g. 03:45.678)" />

            <RadioButton
                android:id="@+id/radioTimeMMSS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MM:SS  (e.g. 03:45)" />

            <RadioButton
                android:id="@+id/radioTimeHMMSSms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H:MM:SS.mmm  (e.g. 0:03:45.678)" />

            <RadioButton
                android:id="@+id/radioTimeHMMSS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H:MM:SS  (e.g. 0:03:45)" />
        </RadioGroup>

        <TextView
            android:id="@+id/textTimeFormatExample"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <!-- Fullscreen background -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_fullscreen_bg" />

        <LinearLayout
            android:id="@+id/rowFullscreenBg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSettingsDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="16dp"
            android:text="@string/done" />

    </LinearLayout>
</ScrollView>
